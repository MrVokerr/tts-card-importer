{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MrVokerr/tts-card-importer/r2/card-index.manifest",
  "title": "CardIndexManifest",
  "type": "object",
  "required": ["version", "shardUrls"],
  "properties": {
    "version": { "type": "integer", "minimum": 2 },
    "updatedAt": { "type": "string", "format": "date-time" },
    "publicBaseUrl": { "type": "string", "format": "uri" },
    "mode": { "enum": ["seed-only", "full"] },
    "stats": {
      "type": "object",
      "properties": {
        "entries": { "type": "integer" },
        "recordShardCount": { "type": "integer" },
        "nameShardCount": { "type": "integer" },
        "setColShardCount": { "type": "integer" },
        "oracleShardCount": { "type": "integer" },
        "nameEntries": { "type": "integer" },
        "setColEntries": { "type": "integer" },
        "oracleEntries": { "type": "integer" }
      }
    },
    "shardUrls": {
      "type": "object",
      "required": ["record", "name", "setCollector", "oracleId", "printings"],
      "properties": {
        "record": { "type": "string" },
        "name": { "type": "string" },
        "setCollector": { "type": "string" },
        "oracleId": { "type": "string" },
        "printings": { "type": "string" }
      }
    }
  }
}
